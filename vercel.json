{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/sitemap-:number.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/sitemap-test.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/quiz", "destination": "/quiz.html" },
    { "source": "/practice", "destination": "/practice.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/us", "destination": "/us.html" },
    { "source": "/uk", "destination": "/uk.html" },
    { "source": "/in", "destination": "/in.html" },
    { "source": "/pk", "destination": "/pk.html" },
    { "source": "/ca", "destination": "/ca.html" },
    { "source": "/au", "destination": "/au.html" },
    { "source": "/ng", "destination": "/ng.html" },
    { "source": "/za", "destination": "/za.html" }
  ],
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/admin", "destination": "/admin.html", "permanent": true },
    { "source": "/bulk-upload", "destination": "/bulk-upload.html", "permanent": true },
    { "source": "/mcq", "destination": "/mcq.html", "permanent": true },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "bookmcq.com"
        }
      ],
      "destination": "https://www.bookmcq.com/$1",
      "permanent": true
    }
  ],
  "trailingSlash": false
}
